---
interface FAQ {
  question: string;
  answer:   string;
}

interface Props {
  items: FAQ[];
}

const { items } = Astro.props;

// FAQPage JSON-LD — consumed by ArticleLayout's <head> via slot or injected inline
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<section class="my-12 border-t border-espresso/15 pt-8">
  <p class="small-caps font-body text-xs text-espresso/45 tracking-widest mb-8">
    Common Questions
  </p>

  <dl class="space-y-8">
    {items.map(item => (
      <div>
        <dt class="font-display text-xl text-ink mb-2 leading-snug">
          {item.question}
        </dt>
        <dd class="font-body text-base text-espresso leading-[1.75]">
          {item.answer}
        </dd>
      </div>
    ))}
  </dl>
</section>
