---
import { authorsBySlug } from '../../data/authors';

interface Props {
  authorSlug: string;
}

const { authorSlug } = Astro.props;
const author = authorsBySlug[authorSlug];
if (!author) return;
---

<div class="mt-16 pt-8 border-t border-espresso/15 not-prose flex items-start gap-5">
  {author.photo ? (
    <img
      src={author.photo}
      alt={author.name}
      class="w-14 h-14 rounded-full object-cover flex-shrink-0"
    />
  ) : (
    <div
      class="w-14 h-14 rounded-full bg-cream flex-shrink-0 flex items-center justify-center"
      aria-hidden="true"
    >
      <span class="font-display text-xl text-espresso/40">
        {author.name.charAt(0)}
      </span>
    </div>
  )}

  <div>
    <p class="font-body text-sm font-medium text-ink mb-1">{author.name}</p>
    <p class="font-body text-sm text-espresso/65 leading-relaxed">{author.bio}</p>
  </div>
</div>
