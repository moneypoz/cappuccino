---
import { productsBySlug } from '../../data/products';

interface Props {
  slugs: string[];
}

const { slugs } = Astro.props;
const products = slugs.map(s => productsBySlug[s]).filter(Boolean);

if (products.length === 0) return;

const trackUrl = (url: string) => {
  const sep = url.includes('?') ? '&' : '?';
  return `${url}${sep}ref=cappuccino`;
};
---

<section class="mt-16 pt-8 border-t border-espresso/15 not-prose">
  <p class="small-caps font-body text-xs text-espresso/45 tracking-widest mb-6">
    Gear Referenced in This Article
  </p>

  <ul class="space-y-5">
    {products.map(product => (
      <li class="flex items-start justify-between gap-6 flex-wrap">
        <div>
          <p class="font-body text-sm font-medium text-ink">
            {product.brand} {product.name}
            <span class="font-normal text-espresso/50 ml-2">{product.priceRange}</span>
          </p>
          <p class="font-body text-xs text-espresso/55 mt-0.5">{product.whoItsFor}</p>
        </div>

        <div class="flex items-center gap-3 flex-wrap">
          {product.reviewSlug && (
            <a
              href={`/gear/${product.reviewSlug}`}
              class="font-body text-xs text-espresso/60 underline underline-offset-4 decoration-espresso/25 hover:text-ink transition-colors duration-150"
            >
              Full review
            </a>
          )}
          {product.affiliateLinks[0] && (
            <a
              href={trackUrl(product.affiliateLinks[0].url)}
              rel="sponsored nofollow"
              target="_blank"
              class="font-body text-xs text-bone bg-espresso px-3 py-1.5 hover:bg-ink transition-colors duration-150"
            >
              Buy &rarr;
            </a>
          )}
        </div>
      </li>
    ))}
  </ul>

  <p class="font-body text-xs text-espresso/35 mt-6">
    Product links are affiliate links. We earn a small commission at no cost to you.{' '}
    <a href="/affiliate-disclosure" class="underline underline-offset-4 decoration-espresso/20 hover:text-ink transition-colors duration-150">
      Full disclosure.
    </a>
  </p>
</section>
