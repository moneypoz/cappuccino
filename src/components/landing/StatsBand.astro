---
interface Stat {
  value: string;
  label: string;
}

const stats: Stat[] = [
  { value: '4.6★',   label: 'Average Rating'    },
  { value: '27,400', label: 'Customer Reviews'  },
  { value: '800+',   label: 'Sold Last Month'   },
  { value: '#1',     label: "Amazon's Choice"   },
];
---

<section class="bg-[#0e0e0e] text-white px-8 py-12">
  <div class="max-w-[1280px] mx-auto grid grid-cols-2 lp:grid-cols-4">
    {stats.map((stat, i) => (
      <div
        class:list={[
          'text-center p-5 lp:px-4 lp:py-2',
          i < stats.length - 1 && 'lp:border-r lp:border-white/[0.08]',
          i < stats.length - 2 && 'border-b border-white/[0.08] lp:border-b-0',
        ]}
      >
        <div class="font-lp-display font-bold text-[36px] lp:text-[48px] leading-none text-lp-gold mb-3 -tracking-[0.01em]">
          {stat.value}
        </div>
        <div class="text-[11px] uppercase tracking-[0.18em] text-white/55 font-medium">
          {stat.label}
        </div>
      </div>
    ))}
  </div>
</section>
