---
interface Props {
  affiliateHref: string;
}

const { affiliateHref } = Astro.props;
---

<section
  class="text-white px-6 py-20 lp:px-8 lp:py-30 text-center"
  style="background: radial-gradient(circle at 50% 100%, rgba(224, 130, 60, 0.18) 0%, transparent 55%), #0e0e0e;"
>
  <div class="max-w-[720px] mx-auto">
    <h2 class="font-lp-display font-bold text-white leading-[1.1] mb-5 text-[clamp(44px,5vw,60px)]">
      Your Dream Cappuccino<br />Is One Click Away
    </h2>
    <p class="text-[17px] text-white/65 mb-9 leading-[1.55]">
      Join 27,400+ happy owners who made the upgrade. Amazon's Choice for a reason.
    </p>
    <a
      href={affiliateHref}
      rel="sponsored noopener"
      target="_blank"
      class="inline-flex items-center justify-center gap-2.5 bg-lp-orange text-white text-[15px] lp:text-[17px] font-semibold no-underline rounded-[4px] px-8 py-[18px] lp:px-11 lp:py-[22px] hover:bg-lp-orange-bright hover:-translate-y-px transition-all duration-200"
      style="box-shadow: 0 0 60px rgba(224, 130, 60, 0.4);"
    >
      Shop This Look Now on Amazon →
    </a>
    <div class="mt-7 text-[13px] text-white/50 flex justify-center gap-7 flex-wrap">
      <span>🔒 Secure Amazon Checkout</span>
      <span>↩ Easy Returns</span>
    </div>
  </div>
</section>
