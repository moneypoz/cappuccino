---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const { title, description, pubDate, author, heroImage } = post.data;

const canonicalURL  = `https://cappuccino.io/blog/${post.id}`;
const pageTitle     = `${title} | cappuccino.io`;
const ogImage       = heroImage ?? 'https://cappuccino.io/og-image.jpg';

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year:  'numeric',
  month: 'long',
  day:   'numeric',
});

const articleSchema = {
  '@context':      'https://schema.org',
  '@type':         'Article',
  headline:        title,
  description,
  image:           ogImage,
  datePublished:   pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name:    author,
    url:     'https://cappuccino.io/author/sara-vitale',
  },
  publisher: {
    '@type': 'Organization',
    name:    'cappuccino.io',
    url:     'https://cappuccino.io',
  },
};
---

<BlogLayout
  title={pageTitle}
  description={description}
  canonicalURL={canonicalURL}
  ogTitle={title}
  ogDescription={description}
  ogImage={ogImage}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  <article class="max-w-[720px] mx-auto px-6 pt-16 pb-24">

    <header class="mb-12">
      <p class="text-[12px] text-lp-green uppercase tracking-[0.18em] font-semibold mb-5">
        Reading
      </p>
      <h1 class="font-lp-display font-bold text-[clamp(36px,4.6vw,56px)] leading-[1.08] -tracking-[0.015em] text-lp-ink mb-6">
        {title}
      </h1>
      <div class="flex items-center gap-3 text-[14px] text-lp-ink-soft">
        <span>By {author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    <div class="article-prose">
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-lp-line text-center">
      <a href="/blog" class="text-[13px] text-lp-green uppercase tracking-[0.14em] font-semibold no-underline hover:text-lp-ink">
        &larr; More reading
      </a>
    </footer>

  </article>
</BlogLayout>

<style is:global>
  .article-prose {
    font-family: var(--font-lp-body);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-lp-ink);
  }
  .article-prose > * + * { margin-top: 1.4em; }

  .article-prose h2 {
    font-family: var(--font-lp-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 2.4vw, 2.125rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-lp-ink);
    margin-top: 2.6em;
    margin-bottom: 0.4em;
  }
  .article-prose h3 {
    font-family: var(--font-lp-display);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.25;
    color: var(--color-lp-ink);
    margin-top: 2em;
    margin-bottom: 0.3em;
  }

  .article-prose p {
    color: var(--color-lp-ink);
  }

  .article-prose em {
    font-style: italic;
  }

  .article-prose strong {
    font-weight: 700;
    color: var(--color-lp-ink);
  }

  .article-prose a {
    color: var(--color-lp-green);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .article-prose a:hover {
    color: var(--color-lp-ink);
  }

  .article-prose ul,
  .article-prose ol {
    padding-left: 1.5em;
  }
  .article-prose li + li {
    margin-top: 0.45em;
  }

  .article-prose blockquote {
    font-family: var(--font-lp-display);
    font-style: italic;
    font-size: 1.35rem;
    line-height: 1.45;
    border-left: 3px solid var(--color-lp-green);
    padding-left: 1.25em;
    color: var(--color-lp-ink-soft);
    margin: 2em 0;
  }

  .article-prose hr {
    border: none;
    border-top: 1px solid var(--color-lp-line);
    width: 60%;
    margin: 2.6em auto;
  }
</style>
