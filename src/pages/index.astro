---
import '../styles/global.css';
import HeroSection      from '../components/landing/HeroSection.astro';
import StatsBand        from '../components/landing/StatsBand.astro';
import FeatureGrid      from '../components/landing/FeatureGrid.astro';
import IncludedSection  from '../components/landing/IncludedSection.astro';
import ReviewsSection   from '../components/landing/ReviewsSection.astro';
import FinalCTA         from '../components/landing/FinalCTA.astro';
import heroImage        from '../assets/breville-hero.png';

const title         = "The Best Cappuccino Machine | Amazon's Choice — cappuccino.io";
const description   = "Amazon's Choice for cappuccino machines. Built-in grinder, real steam wand, decade-long build quality. The Breville Barista Express, reviewed.";
const affiliateHref = 'https://amzn.to/4uypdmM';
const canonicalURL  = 'https://cappuccino.io';

const ogTitle       = "The Best Cappuccino Machine | cappuccino.io";
const ogDescription = "Café-quality espresso without the café visit. The Breville Barista Express, reviewed — our editor's pick for serious home cappuccinos.";
const ogUrl         = 'https://cappuccino.io';
const ogImage       = 'https://cappuccino.io/og-image.jpg';
const ogImageAlt    = 'Breville Barista Express espresso machine on a kitchen counter pulling a shot of espresso';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {/* Open Graph (Facebook, LinkedIn, iMessage, Slack, Discord, WhatsApp) */}
    <meta property="og:type"           content="website" />
    <meta property="og:site_name"      content="cappuccino.io" />
    <meta property="og:url"            content={ogUrl} />
    <meta property="og:title"          content={ogTitle} />
    <meta property="og:description"    content={ogDescription} />
    <meta property="og:image"          content={ogImage} />
    <meta property="og:image:width"    content="1200" />
    <meta property="og:image:height"   content="630" />
    <meta property="og:image:alt"      content={ogImageAlt} />
    <meta property="og:locale"         content="en_US" />

    {/* Twitter Card */}
    <meta name="twitter:card"          content="summary_large_image" />
    <meta name="twitter:url"           content={ogUrl} />
    <meta name="twitter:title"         content={ogTitle} />
    <meta name="twitter:description"   content={ogDescription} />
    <meta name="twitter:image"         content={ogImage} />
    <meta name="twitter:image:alt"     content={ogImageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://cappuccino.io/#organization",
          "name": "cappuccino.io",
          "url": "https://cappuccino.io",
          "description": "Editorial cappuccino reviews and recommendations. One drink. Done right."
        },
        {
          "@type": "WebSite",
          "@id": "https://cappuccino.io/#website",
          "url": "https://cappuccino.io",
          "name": "cappuccino.io",
          "publisher": { "@id": "https://cappuccino.io/#organization" }
        },
        {
          "@type": "Person",
          "@id": "https://cappuccino.io/#author-sara-vitale",
          "name": "Sara Vitale",
          "description": "Coffee writer and longtime home espresso enthusiast. Reviews cappuccino equipment for cappuccino.io.",
          "url": "https://cappuccino.io/author/sara-vitale"
        },
        {
          "@type": "Product",
          "@id": "https://cappuccino.io/#product-breville-barista-express",
          "name": "Breville Barista Express (BES870BTR)",
          "brand": { "@type": "Brand", "name": "Breville" },
          "model": "BES870BTR",
          "category": "Semi-Automatic Espresso Machine",
          "description": "Semi-automatic espresso machine with integrated conical burr grinder, 15-bar Italian pump, articulated steam wand, and pre-infusion. Built for serious home cappuccino.",
          "image": "https://cappuccino.io/breville-hero.png",
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.6",
            "reviewCount": "27400",
            "bestRating": "5",
            "worstRating": "1"
          }
        },
        {
          "@type": "Review",
          "@id": "https://cappuccino.io/#editorial-review",
          "itemReviewed": { "@id": "https://cappuccino.io/#product-breville-barista-express" },
          "author": { "@id": "https://cappuccino.io/#author-sara-vitale" },
          "publisher": { "@id": "https://cappuccino.io/#organization" },
          "datePublished": "2026-05-11",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "4.8",
            "bestRating": "5",
            "worstRating": "1"
          },
          "name": "Breville Barista Express Review: The Cappuccino Machine We'd Actually Buy",
          "reviewBody": "Built-in conical burr grinder, articulated single-hole steam wand, low-pressure pre-infusion, and a decade-long build reputation. Nothing under $1,000 touches it for serious home cappuccino. Real learning curve, single-boiler limitation, and a substantial counter footprint — but for one to three caps a day done right, it's the best machine for the money."
        }
      ]
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    {/* Playfair Display + Inter — deliberate departure from the editorial
        Instrument Serif/Inter Tight pair, per the source design. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;0,800;1,500;1,600;1,700&family=Inter:wght@400;500;600;700&display=swap"
    />

    {/* Clicky analytics — anonymous, no cookie banner needed for US traffic. */}
    <script is:inline>
      (function() {
        var s = document.createElement('script');
        s.type = 'text/javascript';
        s.async = true;
        s.src = '//static.getclicky.com/js';
        s.setAttribute('data-id', 101381681);
        (document.head || document.body).appendChild(s);
      })();
    </script>

    {/* Google Analytics 4 (gtag.js) */}
    <script async is:inline src="https://www.googletagmanager.com/gtag/js?id=G-L8BF6D6CMQ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-L8BF6D6CMQ');
    </script>
  </head>

  <body class="font-lp-body bg-white text-lp-ink antialiased text-[16px] leading-[1.6]">

    {/* ── Top bar — black with orange Amazon's Choice ────────────────────── */}
    <div class="bg-[#0e0e0e] text-white text-center px-4 py-3.5 text-[14px] font-normal">
      <span class="text-lp-orange font-semibold">✦ Amazon's Choice</span> for Cappuccino Machines
    </div>

    <main>
      <HeroSection      affiliateHref={affiliateHref} imageSrc={heroImage} />
      <StatsBand />
      <FeatureGrid />
      <IncludedSection  affiliateHref={affiliateHref} imageSrc={heroImage} />
      <ReviewsSection   affiliateHref={affiliateHref} />
      <FinalCTA         affiliateHref={affiliateHref} />
    </main>

    {/* ── Footer — affiliate disclosure ──────────────────────────────────── */}
    <footer class="bg-lp-cream px-8 py-8 text-center text-[13px] text-lp-ink-soft border-t border-lp-line">
      <div class="mb-4">
        <a href="/blog" class="text-lp-ink underline underline-offset-[3px]">Reading</a>
      </div>
      This page contains affiliate links. As an Amazon Associate, we may earn from qualifying purchases at no extra cost to you.
      <br /><br />
      <a
        href={affiliateHref}
        rel="sponsored noopener"
        target="_blank"
        class="text-lp-ink underline underline-offset-[3px]"
      >
        View product on Amazon
      </a>
    </footer>

    {/* Clicky no-JS fallback pixel */}
    <noscript><p><img alt="Clicky" width="1" height="1" src="//in.getclicky.com/101381681ns.gif" /></p></noscript>

  </body>
</html>
